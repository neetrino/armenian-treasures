# Neon Postgres (pooled connection for app runtime, direct for migrations)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.eu-central-1.aws.neon.tech/armenian_treasures?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/armenian_treasures?sslmode=require"

# NextAuth v5 / Auth.js
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="change-me"
AUTH_URL="http://localhost:3000"

# Storage driver: "local" (dev) or "r2" (prod)
STORAGE_DRIVER="local"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Seeded admin credentials (used by prisma/seed.ts)
ADMIN_SEED_EMAIL="admin@armeniantreasures.org"
ADMIN_SEED_PASSWORD="ChangeMe!2026"
