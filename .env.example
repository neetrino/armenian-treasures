# Neon Postgres (pooled connection for app runtime, direct for migrations)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.eu-central-1.aws.neon.tech/armenian_treasures?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/armenian_treasures?sslmode=require"

# NextAuth v5 / Auth.js
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="change-me"
AUTH_URL="http://localhost:3000"
# Canonical public origin (metadata, sitemap, robots). Must match AUTH_URL / NEXTAUTH_URL in production.
SITE_URL="http://localhost:3000"
#
# Storage driver: "local" (dev) or "r2" (prod)
STORAGE_DRIVER="local"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""
# Optional custom S3 endpoint (defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com)
R2_ENDPOINT=""

# Serve migrated /public assets from R2 (opt-in after running pnpm r2:migrate-public)
USE_R2_PUBLIC_ASSETS="false"
NEXT_PUBLIC_USE_R2_PUBLIC_ASSETS="false"
NEXT_PUBLIC_R2_PUBLIC_URL=""

# Rate limiting (Upstash Redis REST API — required in production multi-instance)
# Set RATE_LIMIT_ENABLED=true only after Redis credentials are configured.
# Vercel Upstash integration sets UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
# (also accepted as aliases for RATE_LIMIT_REDIS_* below).
RATE_LIMIT_ENABLED="false"
RATE_LIMIT_REDIS_URL=""
RATE_LIMIT_REDIS_TOKEN=""
# Emergency opt-out for single-node staging only — NOT for multi-instance production.
# When true, skips the production fail-fast check and allows in-memory limiters.
RATE_LIMIT_ALLOW_IN_MEMORY="false"
TRUSTED_PROXY_HEADERS="false"

# Upload validation
UPLOAD_MAX_FILE_SIZE="10485760"
UPLOAD_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"

# Admin users are created via CLI: pnpm admin:create
# Do NOT store admin email/password in env.
